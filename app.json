{
  "expo": {
    "name": "Sed_Ecomm",
    "slug": "sed-ecomm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "scheme": "sedecomm",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#030712"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sedecomm.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sedecomm.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#030712"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/notification-icon.png",
          "color": "#6366F1"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://sed-ecomm-server.onrender.com/api/v1",
      "eas": {
        "projectId": "eeb92883-162c-4b5a-8fbc-96345aa2c63d"
      }
    },
    "owner": "abdullah_1010"
  }
}
